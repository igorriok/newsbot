TELEGRAM_BOT_TOKEN=your_bot_token_here
OPENCODE_SERVER_URL=http://localhost:4096
OPENCODE_PROVIDER_ID=opencode-go
OPENCODE_MODEL_ID=deepseek-v4-flash
DATABASE_PATH=./data/newsbot.db
# Comma-separated Telegram user IDs allowed to use the bot (get yours from @userinfobot)
ADMIN_TELEGRAM_IDS=123456789
# Cron schedule for feed polling / classification / notification cycle
POLL_CRON_SCHEDULE=*/10 * * * *
# Minimum classifier score (0-1) required for a match to count as relevant, even if the model says "relevant: true"
MIN_RELEVANCE_SCORE=0.5
